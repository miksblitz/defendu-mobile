# Optional: API base URL (forgot password, reset). Default: https://defendu-mobile.vercel.app
# EXPO_PUBLIC_API_BASE_URL=https://defendu-mobile.vercel.app

# Pose extraction: when a trainer publishes with a technique video, the app calls this URL.
# Deploy the pose-service on Render (see pose-service/README.md), then set the Render service URL here.
# Example: EXPO_PUBLIC_POSE_EXTRACTION_URL=https://your-pose-service.onrender.com
# Restart Metro after changing this. If not set, referencePoseSequenceUrl will never be added to modules.
EXPO_PUBLIC_POSE_EXTRACTION_URL=
