{
  "expo": {
    "name": "DEFENDU",
    "slug": "defendu-mobile",
    "scheme": "defenduapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "updates": {
      "enabled": false
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSCameraUsageDescription": "This app uses the camera for pose-based technique feedback during exercises."
      }
    },
    "android": {
      "package": "com.defendu.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-camera",
      [
        "expo-image-picker",
        {
          "colors": {
            "cropToolbarColor": "#f0f4f8",
            "cropToolbarIconColor": "#041527",
            "cropToolbarActionTextColor": "#041527",
            "cropBackButtonIconColor": "#041527",
            "cropBackgroundColor": "#ffffff"
          }
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "013c0a8a-c020-4d00-8421-58db0e1304ea"
      }
    }
  }
}
